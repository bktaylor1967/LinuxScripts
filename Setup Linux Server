#!/usr/bin/env bash

# Exit on error
set -e

# Ensure the script is run as root
if [[ $EUID -ne 0 ]]; then
   echo "This script must be run as root (use sudo)."
   exit 1
fi

# 1. Capture User Variables
echo "--- Samba Share Configuration ---"
read -p "Enter Share Name (e.g., MyShare): " SHARE_NAME
read -p "Enter Share Group (e.g., sambagroup): " SHARE_GROUP
read -p "Enter Storage Path (e.g., /srv/samba/data): " SHARE_PATH

# 2. Update and Install Samba
echo "Updating repositories and installing Samba..."
apt-get update -qq
apt-get install -y samba > /dev/null

# 3. Create Group and Directory
if ! getent group "$SHARE_GROUP" > /dev/null; then
    echo "Creating group: $SHARE_GROUP"
    groupadd "$SHARE_GROUP"
fi

echo "Setting up directory: $SHARE_PATH"
mkdir -p "$SHARE_PATH"
chgrp "$SHARE_GROUP" "$SHARE_PATH"
# 2770: Sticky bit on group (2), Owner/Group Full (7), Others None (0)
chmod 2770 "$SHARE_PATH"

# 4. Update Samba Configuration
if grep -q "\[$SHARE_NAME\]" /etc/samba/smb.conf; then
    echo "Warning: Share [$SHARE_NAME] already exists in /etc/samba/smb.conf. Skipping config append."
else
    echo "Appending $SHARE_NAME to /etc/samba/smb.conf..."
    cat <<EOF >> /etc/samba/smb.conf

[$SHARE_NAME]
    comment = Restricted Group Share
    path = $SHARE_PATH
    browsable = yes
    read only = no
    guest ok = no
    valid users = @$SHARE_GROUP
    force group = $SHARE_GROUP
    create mask = 0660
    directory mask = 0770
EOF
fi

# 5. Finalize Services
echo "Restarting Samba services..."
systemctl restart smbd nmbd

# 6. Firewall Configuration
if command -v ufw > /dev/null && ufw status | grep -q "Status: active"; then
    echo "Adjusting UFW firewall rules..."
    ufw allow 'Samba'
fi

# 7. Summary
echo "-------------------------------------------------------"
echo " SUCCESS: $SHARE_NAME has been set up at $SHARE_PATH"
echo "-------------------------------------------------------"
echo "Next Steps:"
echo " 1. Add a Linux user to the group:"
echo "    sudo usermod -aG $SHARE_GROUP <username>"
echo ""
echo " 2. Set the Samba password for that user:"
echo "    sudo smbpasswd -a <username>"
echo "-------------------------------------------------------"
