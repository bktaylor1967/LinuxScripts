version: '3.8'

services:
  gluetun:
    image: qmcgaw/gluetun
    container_name: gluetun
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun
    ports:
      - 8085:8085  # SABnzbd
      - 8989:8989  # Sonarr
      - 7878:7878  # Radarr
      - 9696:9696  # Prowlarr
      - 8787:8787  # Readarr
      - 8686:8686  # Lidarr
      - 8080:8080  # qBittorrent
      - 5055:5055  # Jellyseerr
    environment:
      - VPN_SERVICE_PROVIDER= # Add your provider
      - OPENVPN_USER= # Add your user
      - OPENVPN_PASSWORD= # Add your password

  sabnzbd:
    image: lscr.io/linuxserver/sabnzbd:latest
    container_name: sabnzbd
    network_mode: "service:gluetun"
    environment:
      - PUID=1000
      - PGID=1000
    volumes:
      - ./config/sabnzbd:/config
      - /data:/data
    restart: unless-stopped

  # Add your other services (Sonarr, Radarr, Jellyseerr, etc.) below
  # ensuring network_mode is set to service:gluetun for those requiring VPN
