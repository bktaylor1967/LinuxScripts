#!/bin/bash

# --- Interactive Input Section ---
echo "--- Proxmox Kali LXC Configuration ---"

# Suggest next available ID
NEXT_ID=$(pvesh get /cluster/nextid)
read -p "Enter Container ID [$NEXT_ID]: " CT_ID
CT_ID=${CT_ID:-$NEXT_ID}

read -p "Enter Container Name [Kali-LXC]: " CT_NAME
CT_NAME=${CT_NAME:-Kali-LXC}

read -p "Enter Disk Size in GB [20]: " DISK_SIZE
DISK_SIZE=${DISK_SIZE:-20}

read -p "Enter Storage Pool [local-lvm]: " STORAGE
STORAGE=${STORAGE:-local-lvm}

read -p "Enter Bridge Interface [vmbr0]: " BRIDGE
BRIDGE=${BRIDGE:-vmbr0}

read -p "Enter New Username [kaliuser]: " USERNAME
USERNAME=${USERNAME:-kaliuser}

read -s -p "Enter Password for Root and $USERNAME: " PASSWORD
echo -e "\n"

# --- Template Acquisition Section ---
# We bypass pveam and go straight to the LXC mirrors

echo "🔍 Finding the latest Kali build from images.linuxcontainers.org..."
BASE_URL="https://images.linuxcontainers.org/images/kali/current/amd64/default/"
# This scrapes the directory listing for the most recent date folder
LATEST_DATE=$(curl -s $BASE_URL | grep -oE '[0-9]{8}_[0-9]{2}:[0-9]{2}' | tail -n 1)

if [ -z "$LATEST_DATE" ]; then
    echo "❌ Error: Could not reach the download mirror. Check internet/DNS."
    exit 1
fi

DOWNLOAD_URL="${BASE_URL}${LATEST_DATE}/rootfs.tar.xz"
TEMPLATE_DEST="/var/lib/vz/template/cache/kali-manual-${LATEST_DATE//[: ]/_}.tar.xz"

if [ ! -f "$TEMPLATE_DEST" ]; then
    echo "📥 Downloading: $DOWNLOAD_URL"
    wget "$DOWNLOAD_URL" -O "$TEMPLATE_DEST"
else
    echo "✅ Template already exists at $TEMPLATE_DEST"
fi

# --- Container Creation Section ---

echo "🚀 Creating container $CT_ID..."
# Note: We use the local file path directly here
pct create "$CT_ID" "$TEMPLATE_DEST" \
    --hostname "$CT_NAME" \
    --password "$PASSWORD" \
    --storage "$STORAGE" \
    --rootfs "$STORAGE:$DISK_SIZE" \
    --cores 2 \
    --memory 2048 \
    --net0 name=eth0,bridge="$BRIDGE",ip=dhcp \
    --ostype debian \
    --unprivileged 1 \
    --start 1

echo "⏳ Waiting for boot..."
sleep 15

# --- Post-Install Configuration ---

echo "👤 Setting up user $USERNAME..."
pct exec "$CT_ID" -- apt-get update
pct exec "$CT_ID" -- apt-get install -y sudo
pct exec "$CT_ID" -- useradd -m -s /bin/bash -G sudo "$USERNAME"
pct exec "$CT_ID" -- bash -c "echo '$USERNAME:$PASSWORD' | chpasswd"

echo -e "\n--- ✅ DONE ---"
echo "ID: $CT_ID | User: $USERNAME"
echo "Login via Web Console or run: pct enter $CT_ID"
