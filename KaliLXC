#!/bin/bash

# --- Interactive Input Section ---
echo "--- Proxmox Kali LXC Configuration ---"

# Suggest next available ID
NEXT_ID=$(pvesh get /cluster/nextid)
read -p "Enter Container ID [$NEXT_ID]: " CT_ID
CT_ID=${CT_ID:-$NEXT_ID}

read -p "Enter Container Name [Kali-LXC]: " CT_NAME
CT_NAME=${CT_NAME:-Kali-LXC}

read -p "Enter Disk Size in GB [20]: " DISK_SIZE
DISK_SIZE=${DISK_SIZE:-20}

read -p "Enter Storage Pool [local-lvm]: " STORAGE
STORAGE=${STORAGE:-local-lvm}

read -p "Enter Bridge Interface [vmbr0]: " BRIDGE
BRIDGE=${BRIDGE:-vmbr0}

read -p "Enter New Username [kaliuser]: " USERNAME
USERNAME=${USERNAME:-kaliuser}

read -s -p "Enter Password for Root and $USERNAME: " PASSWORD
echo -e "\n"

# --- Template Acquisition Section ---

# 1. Determine the latest build date from the LXC mirrors
echo "🔍 Finding the latest Kali build..."
BASE_URL="https://images.linuxcontainers.org/images/kali/current/amd64/default/"
LATEST_DATE=$(curl -s $BASE_URL | grep -oE '[0-9]{8}_[0-9]{2}:[0-9]{2}' | tail -n 1)

if [ -z "$LATEST_DATE" ]; then
    echo "❌ Error: Could not find the latest build date. Please check your internet connection."
    exit 1
fi

DOWNLOAD_URL="${BASE_URL}${LATEST_DATE}/rootfs.tar.xz"
TEMPLATE_PATH="/var/lib/vz/template/cache/kali-${LATEST_DATE}.tar.xz"

# 2. Download the template if it doesn't already exist
if [ ! -f "$TEMPLATE_PATH" ]; then
    echo "📥 Downloading Kali template ($LATEST_DATE)..."
    wget "$DOWNLOAD_URL" -O "$TEMPLATE_PATH"
else
    echo "✅ Template already exists locally."
fi

# --- Container Creation Section ---

echo "🚀 Creating container $CT_ID ($CT_NAME)..."
pct create "$CT_ID" "$TEMPLATE_PATH" \
    --hostname "$CT_NAME" \
    --password "$PASSWORD" \
    --storage "$STORAGE" \
    --rootfs "$STORAGE:$DISK_SIZE" \
    --cores 2 \
    --memory 2048 \
    --net0 name=eth0,bridge="$BRIDGE",ip=dhcp \
    --ostype debian \
    --unprivileged 1 \
    --start 1

echo "⏳ Waiting for container to initialize..."
sleep 15

# --- Post-Install Configuration ---

echo "👤 Configuring user: $USERNAME..."
# Ensure sudo is installed first (LXC images are very bare-bones)
pct exec "$CT_ID" -- apt-get update
pct exec "$CT_ID" -- apt-get install -y sudo

# Create user and set password
pct exec "$CT_ID" -- useradd -m -s /bin/bash -G sudo "$USERNAME"
pct exec "$CT_ID" -- bash -c "echo '$USERNAME:$PASSWORD' | chpasswd"

# Optional: Install basic Kali Headless tools
read -p "Install Kali Headless tools? (y/n) [y]: " INSTALL_TOOLS
INSTALL_TOOLS=${INSTALL_TOOLS:-y}

if [[ "$INSTALL_TOOLS" =~ ^[Yy]$ ]]; then
    echo "📦 Installing kali-linux-headless (this takes a while)..."
    pct exec "$CT_ID" -- apt-get install -y kali-linux-headless
fi

echo -e "\n--- ✅ SETUP COMPLETE ---"
echo "Container ID: $CT_ID"
echo "Username: $USERNAME"
echo "You can access the console via the Proxmox UI or: 'pct enter $CT_ID'"
